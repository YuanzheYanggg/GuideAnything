API_PORT=3001
WEB_ORIGIN=http://localhost:5173
DATABASE_PATH=./data/guideanything.sqlite
UPLOAD_DIR=./data/uploads
# Generate a unique value (for example with `openssl rand -hex 32`).
# Production refuses missing, short, or repository-known example values.
JWT_SECRET=
AGENT_RUNTIME_MODE=bridge
SANTEXWELL_VAULT_PATH=
AGENT_BRIDGE_URL=http://127.0.0.1:3010
# Generate a second, different value (for example with `openssl rand -hex 32`).
# Bridge mode always refuses missing, short, or repository-known example values.
AGENT_BRIDGE_TOKEN=
AGENT_MAX_CONCURRENCY=3
AGENT_ROUTER_TIMEOUT_MS=30000
AGENT_WORKER_TIMEOUT_MS=90000
AGENT_REDUCER_TIMEOUT_MS=90000
AGENT_RUN_TIMEOUT_MS=240000
# All five semantic roles must name models exposed by the connected Codex app-server.
# They may point to the same capable reasoning model, but are never silently defaulted.
AGENT_MODEL_ROUTER=
AGENT_MODEL_DEEP_ROUTER=
AGENT_MODEL_FOCUSED_WORKER=
AGENT_MODEL_DEEP_WORKER=
AGENT_MODEL_REDUCER=

# Separate Runtime Bridge process. It always binds 127.0.0.1; no public bind option is supported.
RUNTIME_BRIDGE_PORT=3010
RUNTIME_BRIDGE_MAX_CONCURRENCY=3
RUNTIME_BRIDGE_BODY_LIMIT_BYTES=600000
CODEX_BINARY=codex
# This must be a dedicated directory, never an operator's personal ~/.codex.
CODEX_RUNTIME_HOME=./data/runtime-bridge/codex-home
# Existing regular Codex auth file. The bridge links it as auth.json without reading or copying it.
# It may be omitted only when CODEX_RUNTIME_HOME was already provisioned with a regular auth.json.
CODEX_RUNTIME_AUTH_FILE=
# This directory must remain empty. Vault and workspace evidence is injected in the prompt instead.
CODEX_RUNTIME_WORK_DIR=./data/runtime-bridge/empty-work
CODEX_BASELINE_INPUT_TOKEN_LIMIT=100000
CODEX_TURN_TIMEOUT_MS=120000
CODEX_RPC_TIMEOUT_MS=15000
CODEX_CLOSE_TIMEOUT_MS=2000
VITE_API_BASE=/api

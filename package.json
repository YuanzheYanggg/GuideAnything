{
  "name": "guideanything",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:migrate": "pnpm --filter @guideanything/api db:migrate",
    "db:reset": "pnpm --filter @guideanything/api db:reset",
    "db:seed": "pnpm --filter @guideanything/api db:seed",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:fake": "AGENT_RUNTIME_MODE=fake pnpm --parallel --filter @guideanything/api --filter @guideanything/web dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
